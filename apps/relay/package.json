{
  "name": "@flume/relay",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted relay service — runs FlumeRelay from @flume/arc",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "echo 'relay tests in @flume/arc package'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flume/arc": "workspace:*",
    "@flume/gateway": "workspace:*",
    "express": "^4.21.0",
    "bullmq": "^5.34.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0"
  }
}
