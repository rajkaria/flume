{
  "name": "@flume/sdk",
  "version": "0.1.0",
  "description": "Agent-side client — FlumeClient, FlumeAggregator, framework adapters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
